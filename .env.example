# Copy this file to .env (which is gitignored) for local `netlify dev`.
# In production, set these in Netlify dashboard → Site settings → Environment variables.

# From Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# From Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
